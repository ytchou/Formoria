{
  "name": "formoria",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "next dev",
    "email:dev": "email dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint && pnpm check:frontend-tokens",
    "check:favicon": "node scripts/check-favicon-rgba.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:frontend-tokens": "node scripts/check-frontend-type-tokens.mjs",
    "knip": "knip",
    "prepare": "git config core.hooksPath scripts/hooks 2>/dev/null || true",
    "curate": "tsx --env-file=.env.local scripts/curate-brands.ts",
    "curation:worker": "tsx scripts/curation-worker-server.ts",
    "backfill-images": "tsx --env-file=.env.local scripts/backfill-brand-images.ts",
    "brand-storage-maintenance": "tsx --env-file=.env.local scripts/brand-storage-maintenance.ts",
    "remove-brand": "tsx --env-file=.env.local scripts/remove-brand.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=smoke-chromium --project=smoke-firefox --project=smoke-webkit",
    "test:e2e:deep": "playwright test --project=deep",
    "test:search:load": "node --env-file=.env.local scripts/search-load.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.13",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/ssr": "^0.12.1",
    "@supabase/supabase-js": "^2.110.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "adm-zip": "^0.6.0",
    "agentation": "^3.0.2",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-axiom": "^1.10.0",
    "next-intl": "^4.13.0",
    "next-mdx-remote": "^6.0.0",
    "pinyin-pro": "^3.28.1",
    "posthog-js": "^1.405.2",
    "posthog-node": "^5.46.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.76.0",
    "react-leaflet": "^5.0.0",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.10.0",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "prettier": "^3.9.5",
    "react-email": "^6.6.8",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vite": ">=8.1.4",
    "vitest": "^4.1.9"
  }
}
