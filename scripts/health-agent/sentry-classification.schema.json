{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://formoria.invalid/schemas/sentry-classification.schema.json",
  "title": "SentryClassification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "severity",
    "rootCause",
    "confidence",
    "recurrence",
    "reproducible",
    "fixability",
    "behaviorChangeRisk",
    "sensitivePaths",
    "recommendedAction",
    "mergePolicy"
  ],
  "properties": {
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "rootCause": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "recurrence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "count", "evidence"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["new", "recurring"]
        },
        "count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        },
        "evidence": {
          "type": "string",
          "minLength": 1,
          "maxLength": 400
        }
      }
    },
    "reproducible": {
      "type": "boolean"
    },
    "fixability": {
      "type": "string",
      "enum": ["low", "medium", "high", "unknown"]
    },
    "behaviorChangeRisk": {
      "type": "string",
      "enum": ["low", "medium", "high", "unknown"]
    },
    "sensitivePaths": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 200
      }
    },
    "recommendedAction": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "mergePolicy": {
      "type": "string",
      "enum": ["automatic", "human"]
    }
  }
}
