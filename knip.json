{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/app/**/{page,layout,route,template,error,not-found,loading,opengraph-image,twitter-image,icon,apple-icon,global-error,robots,sitemap}.{ts,tsx}",
    "scripts/**/*.{ts,mjs}",
    "emails/**/*.{ts,tsx}"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "scripts/**/*.{ts,mjs}",
    "emails/**/*.{ts,tsx}",
    "tina/__generated__/client.ts"
  ],
  "ignoreDependencies": ["tw-animate-css", "tailwindcss", "shadcn", "@react-email/ui"],
  "ignoreBinaries": ["dotenv"],
  "ignore": [
    "src/lib/supabase/database.types.ts",
    "scripts/threads-scraper/**",
    "src/lib/services/enrich-phases/scraper/apify.ts"
  ],
  "ignoreIssues": {
    "src/components/ui/card.tsx": ["exports"]
  },
  "paths": {
    "@tina/*": ["tina/__generated__/*"]
  }
}
