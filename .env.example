# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (used for JSON-LD absolute URLs)
NEXT_PUBLIC_SITE_URL=https://formoria.com

# Admin
ADMIN_EMAILS=your-email@example.com

# Personal OS internal executive API
PERSONAL_OS_INTERNAL_TOKEN=

# Railway service logs URL for admin job monitoring
RAILWAY_LOGS_URL=
# Injected by Railway; used for run-log provenance; optional locally.
RAILWAY_GIT_COMMIT_SHA=

# Analytics (optional for dev)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://e.formoria.com
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=
POSTHOG_API_HOST=https://us.posthog.com
POSTHOG_DASHBOARD_URL=

# Sentry (optional for dev)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Axiom (optional for dev — structured production logging)
NEXT_PUBLIC_AXIOM_DATASET=
NEXT_PUBLIC_AXIOM_TOKEN=

# Resend (optional for dev/CI)
RESEND_API_KEY= # Resend API key for transactional owner emails; leave unset to no-op email sending

# Google Maps (optional — only for retail location widget)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Cloudflare Turnstile (bot detection on submission form + challenge page)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Anti-scraping: Upstash Redis (optional — falls back to in-memory rate limiter)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare origin protection (optional — set when Cloudflare proxy is active)
CF_ORIGIN_SECRET=

# Anti-scraping: Challenge cookie signing secret (required in production)
CHALLENGE_SECRET=

# E2E test accounts (required for pnpm test:e2e)
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=your-admin-password
E2E_USER_EMAIL=testuser@example.com
E2E_USER_PASSWORD=your-user-password

# Enrichment (required for brand enrichment pipeline)
SERPER_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# IndexNow (required for Bing URL submission on deploy)
INDEXNOW_KEY=

# TinaCMS (Tina Cloud)
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=
